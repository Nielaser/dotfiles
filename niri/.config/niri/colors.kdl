layout {
    border {
        active-color   "#80d4dc"
        inactive-color "#899393"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#80d4dc"
        inactive-color "#899393"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#80d4dc80"
    }
}

