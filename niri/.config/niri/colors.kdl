layout {
    border {
        active-color   "#fcb975"
        inactive-color "#9d8e81"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#fcb975"
        inactive-color "#9d8e81"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#fcb97580"
    }
}

