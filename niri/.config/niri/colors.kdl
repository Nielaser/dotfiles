layout {
    border {
        active-color   "#d8bafb"
        inactive-color "#958e99"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#d8bafb"
        inactive-color "#958e99"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#d8bafb80"
    }
}

