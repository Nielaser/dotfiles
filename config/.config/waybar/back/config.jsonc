{
    "layer": "top",
    "modules-left": ["clock"],
    "modules-center": ["niri/window"],
    "modules-right": ["tray","battery"],
    "sway/window": {
        "max-length": 50
    },
    "battery": {
        "format": "{icon}",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },
    "clock": {
        "format-alt": "{:%a, %d. %b  %H:%M}"
    }
}
